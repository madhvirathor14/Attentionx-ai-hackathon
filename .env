# AttentionX — API Keys Configuration
# Copy this file to .env and fill in your keys
# NEVER commit the actual .env file to GitHub

# ─── Groq API Key (FREE) ────────────────────────────────────────────────────
# Get yours at: https://console.groq.com/keys
# Used for: Whisper transcription + LLaMA 3.3 70B for clip analysis
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional: Google Gemini (if you want multimodal video understanding) ──
# Get yours at: https://aistudio.google.com/apikey
# If left blank, the app will use Groq LLaMA (which works great too)
GEMINI_API_KEY=
